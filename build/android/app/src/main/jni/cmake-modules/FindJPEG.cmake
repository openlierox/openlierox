# Drop-in FindJPEG.cmake — see FindPNG.cmake for the rationale. We
# accept either the libjpeg-turbo we add directly (target jpeg-static)
# or the copy SDL_image's vendored sources may pull in.

if(TARGET jpeg-static)
    set(_jpeg_target jpeg-static)
elseif(TARGET libjpeg)
    set(_jpeg_target libjpeg)
elseif(TARGET jpeg)
    set(_jpeg_target jpeg)
endif()

if(_jpeg_target)
    set(JPEG_FOUND TRUE)
    get_target_property(_jpeg_inc ${_jpeg_target} INCLUDE_DIRECTORIES)
    if(NOT _jpeg_inc)
        get_target_property(_jpeg_inc ${_jpeg_target} INTERFACE_INCLUDE_DIRECTORIES)
    endif()
    set(JPEG_INCLUDE_DIR ${_jpeg_inc})
    set(JPEG_INCLUDE_DIRS ${_jpeg_inc})
    set(JPEG_LIBRARY ${_jpeg_target})
    set(JPEG_LIBRARIES ${_jpeg_target})
    set(JPEG_VERSION 30)
    if(NOT TARGET JPEG::JPEG)
        add_library(JPEG::JPEG ALIAS ${_jpeg_target})
    endif()
else()
    include("${CMAKE_ROOT}/Modules/FindJPEG.cmake")
endif()
